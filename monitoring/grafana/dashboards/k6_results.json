{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Active Virtual Users",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 20, "lineWidth": 2 },
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "k6_vus{job=\"k6\"}",
          "legendFormat": "Active VUs",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Requests Per Second (RPS)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 10, "lineWidth": 2 },
          "unit": "reqps"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(k6_http_reqs_total[30s])",
          "legendFormat": "RPS",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Response Time Percentiles",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 0, "lineWidth": 2 },
          "unit": "ms"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(k6_http_req_duration_seconds_bucket[30s])) * 1000",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.90, rate(k6_http_req_duration_seconds_bucket[30s])) * 1000",
          "legendFormat": "p90",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.95, rate(k6_http_req_duration_seconds_bucket[30s])) * 1000",
          "legendFormat": "p95",
          "refId": "C"
        },
        {
          "expr": "histogram_quantile(0.99, rate(k6_http_req_duration_seconds_bucket[30s])) * 1000",
          "legendFormat": "p99",
          "refId": "D"
        }
      ]
    },
    {
      "title": "Error Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "red", "mode": "fixed" },
          "custom": { "fillOpacity": 30, "lineWidth": 2 },
          "unit": "percentunit",
          "max": 1,
          "min": 0
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(k6_http_req_failed_total[30s]) / rate(k6_http_reqs_total[30s])",
          "legendFormat": "Error Rate",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Response Time by Endpoint",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 0, "lineWidth": 1 },
          "unit": "ms"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(k6_http_req_duration_seconds_bucket[30s])) * 1000",
          "legendFormat": "{{ name }} p95",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Booking Metrics",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 100 },
              { "color": "red", "value": 500 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "k6_booking_success_total",
          "legendFormat": "Successful Bookings",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Sold Out Responses",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "orange", "value": null }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "k6_booking_sold_out_total",
          "legendFormat": "Sold Out",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Failed Bookings",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "red", "value": null }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "k6_booking_fail_total",
          "legendFormat": "Failed",
          "refId": "A"
        }
      ]
    },
    {
      "title": "HTTP Requests Total",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 28 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "blue", "value": null }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "k6_http_reqs_total",
          "legendFormat": "Total Requests",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Avg Response Time",
      "type": "gauge",
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 28 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "ms",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 200 },
              { "color": "red", "value": 500 }
            ]
          },
          "max": 2000,
          "min": 0
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(k6_http_req_duration_seconds_sum[1m]) / rate(k6_http_req_duration_seconds_count[1m]) * 1000",
          "legendFormat": "Avg Duration",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Peak VUs",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 28 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "purple", "value": null }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "max_over_time(k6_vus{job=\"k6\"}[1h])",
          "legendFormat": "Peak VUs",
          "refId": "A"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["k6", "performance"],
  "templating": {
    "list": [
      {
        "current": { "selected": false, "text": "Prometheus", "value": "Prometheus" },
        "hide": 0,
        "includeAll": false,
        "multi": false,
        "name": "DS_PROMETHEUS",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "regex": "",
        "type": "datasource"
      }
    ]
  },
  "time": { "from": "now-30m", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "K6 Performance Test Results",
  "uid": "k6-performance-results",
  "version": 1
}
